# Copy this to .env on the droplet and fill in real values. .env is gitignored -
# it never gets committed or pulled from git.

DOMAIN=hactt.tech
SAGILE_DOMAIN=sagilehyperagile.systems

# hactt-backend
DEEPSEEK_API_KEY=
# RSA public key matching SAgileHyperagile's storage/oauth-public.key (Passport JWT
# signing key) - used by hactt-backend to validate SAgile-issued JWTs. Single line,
# no embedded newlines (whitespace is stripped either way).
SAGILE_PUBLIC_KEY=

# notification-services (Mailtrap sandbox or real SMTP creds)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=
SMTP_PASSWORD=

# SAgileHyperagile OAuth client used by hactt-frontend (see oauth_clients table in
# SAgileHyperagile's DB - client id 8, "Hyper Agile Collaboration Testing Tool", is a
# public client with no secret)
SAGILE_CLIENT_ID=8
SAGILE_CLIENT_SECRET=
